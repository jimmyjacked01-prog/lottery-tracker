def calculate_ev_metrics(prizes_left, total_prizes):
    if total_prizes == 0:
        return "UNKNOWN", 0.0
    if prizes_left == 0:
        return "❌ AVOID (Dead Game)", 0.0
        
    ratio = prizes_left / total_prizes
    score = ratio
    
    if ratio >= 0.66:
        rec = "🔥 STRONG BUY"
    elif ratio >= 0.33:
        rec = "✅ BUY"
    else:
        rec = "⚠️ CAUTION"
        
    return rec, score

